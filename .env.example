# PostgreSQL (Docker)
POSTGRES_USER=lazypassword
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lazypassword

# 앱 DB 연결 문자열 (POSTGRES_* 값과 일치시킬 것)
DATABASE_URL=postgresql+psycopg2://lazypassword:change-me@localhost:5432/lazypassword

# 서버 시크릿 키 (세션/토큰 서명용) — 실제 값은 무작위로 생성해 .env에 넣을 것
SECRET_KEY=change-me

# 운영 배포 시 (docker-compose.prod.yml)
#  - DATABASE_URL의 host는 'localhost'가 아니라 'db'(컨테이너 서비스명)가 되어야 한다.
#    예: postgresql+psycopg2://lazypassword:비번@db:5432/lazypassword
#    (docker-compose.prod.yml이 이 값을 자동 구성하므로 .env에는 POSTGRES_*만 있어도 됨)
#  - HTTPS 적용 후 secure 세션 쿠키를 켠다:
SESSION_HTTPS_ONLY=false
